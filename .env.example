# Skeleton — Reverse Engineering Agent

# === LLM 配置 ===
SKELETON_PROTOCOL=openai         # openai | anthropic
SKELETON_API_KEY=sk-xxx          # 你的 API Key
SKELETON_BASE_URL=https://api.openai.com   # /v1 前面的部分
SKELETON_MODEL=gpt-4o            # 模型名

# === Telegram 网关 ===
SKELETON_TG_TOKEN=               # Bot Token（仅网关模式需要）
