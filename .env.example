# Skeleton — Reverse Engineering Agent

# ═══ LLM 配置 ═══
SKELETON_PROTOCOL=openai                     # openai | anthropic — 两种协议，二选一
SKELETON_API_KEY=sk-xxx                      # 你的 API Key
SKELETON_BASE_URL=https://api.openai.com     # 基础 URL（/v1 前面的部分，SDK 自动拼 /v1）
SKELETON_MODEL=gpt-4o                        # 模型名（或任意自定义模型）

# ═══ Telegram 网关（仅 npm run tg 时需要）═══
SKELETON_TG_TOKEN=                           # Bot Token（从 @BotFather 获取）

# 谁能跟机器人对话？
#   *           = 所有人（默认）
#   123456      = 仅该用户
#   123,456     = 白名单，逗号分隔多个 user ID
SKELETON_TG_ALLOWED_USERS=*

# 机器人在群组中的行为：
#   off        = 完全不回群组消息（只接受私聊）
#   mention    = 仅被 @机器人 时才回复（默认）
#   all        = 群里所有消息都回复
SKELETON_TG_GROUP_MODE=mention

# 消息表情反馈（处理中👀 / 成功👍 / 失败👎）：
#   true       = 开启（默认）
#   false      = 关闭
SKELETON_TG_REACTIONS=true

# ═══ Skills & MCP ═══
# CTF 知识库（solve-challenge 编排器 + 11 个分类工作流）：
#   true       = 开启（默认）
#   false      = 关闭
#   auto       = 自动检测
SKELETON_CTF_SKILLS=true

# jshookmcp 浏览器逆向工具（387 工具，36 域）：
#   true       = 开启（默认，自动通过 npx 启动 @jshookmcp/jshook@latest）
#   false      = 关闭
SKELETON_JSHOOK=true
